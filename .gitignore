# Raw data - large files, not tracked (document how to obtain in README instead)
data/raw/*
!data/raw/.gitkeep

# Exception: curated analysis inputs (small, provenance-documented, portfolio-worthy)
!data/raw/annotation/
data/raw/annotation/*
!data/raw/annotation/candidate_genes.txt

# Large processed intermediate files
data/processed/*.rds
data/processed/*.RData
data/processed/*.idat
data/processed/*.idat.gz

# Full genome-wide result tables: large (~35 MB gzipped) and regenerable by the
# scripts. Track only the small trimmed subsets (e.g. ewas_diet_significant.csv).
results/tables/ewas_diet_methylation.csv
results/tables/ewas_diet_methylation.csv.gz

# R
.Rhistory
.RData
.Rproj.user/
*.Rproj

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
venv/
.venv/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
